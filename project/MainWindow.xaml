<Window x:Class="project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:project"
        xmlns:viewmodels="clr-namespace:project.ViewModels"
        xmlns:views="clr-namespace:project.Views"
        xmlns:services="clr-namespace:project.Services"
        xmlns:converters="clr-namespace:project.Converters"
        mc:Ignorable="d"
        Title="SoundProject" Height="700" Width="1100" MinWidth="900" MinHeight="600" WindowStartupLocation="CenterScreen"
        Background="#131314">
    
    <Window.Resources>

        <!-- Маппинг ViewModel на View -->
        <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}"><views:HomeView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CatalogViewModel}"><views:CatalogView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:MaterialDetailViewModel}"><views:MaterialDetailView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CalculatorViewModel}"><views:CalculatorView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CabinetViewModel}"><views:CabinetView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:AdminViewModel}"><views:AdminView /></DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
            <Border Background="#1F1F20" CornerRadius="10" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" Width="320">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LoginTitle]}" FontSize="24" FontWeight="Bold" Margin="0,0,0,25" TextAlignment="Center" Foreground="#FFB3B1"/>
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Username]}" Margin="0,0,0,5" Foreground="#999999"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Password]}" Margin="0,0,0,5" Foreground="#999999"/>
                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFB3B1" Margin="0,0,0,15" TextAlignment="Center" TextWrapping="Wrap"/>
                    
                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LoginBtn]}" Command="{Binding LoginCommand}" Style="{StaticResource AccentButton}" Margin="0,0,0,15"/>
                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[NoAccount]}" Command="{Binding GoToRegistrationCommand}" Background="Transparent" BorderThickness="0" Foreground="#FFB3B1" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:RegistrationViewModel}">
            <Border Background="#1F1F20" CornerRadius="10" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" Width="320">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RegisterTitle]}" FontSize="24" FontWeight="Bold" Margin="0,0,0,25" TextAlignment="Center" Foreground="#FFB3B1"/>
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Username]}" Margin="0,0,0,5" Foreground="#999999"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>
                    
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[EmailLbl]}" Margin="0,0,0,5" Foreground="#999999"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>

                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Password]}" Margin="0,0,0,5" Foreground="#999999"/>
                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[ConfirmPassword]}" Margin="0,0,0,5" Foreground="#999999"/>
                    <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>
                    
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFB3B1" Margin="0,0,0,15" TextAlignment="Center" TextWrapping="Wrap"/>
                    
                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RegisterBtn]}" Command="{Binding RegisterCommand}" Style="{StaticResource AccentButton}" Margin="0,0,0,15"/>
                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[GoBack]}" Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Foreground="#999999" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type viewmodels:CartViewModel}">
            <views:CartView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type viewmodels:ExecutorViewModel}">
            <views:ExecutorView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER NAVIGATION -->
        <Border Background="#1F1F20" Padding="20,15" BorderBrush="#2A2A2B" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SOUND" Foreground="#E0E0E0" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="PROJECT" Foreground="#FFB3B1" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
                
                <!-- Меню справа -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Visibility="{Binding MenuVisibility}">
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Home]}" Command="{Binding GoToHomeCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Catalog]}" Command="{Binding GoToCatalogCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Calculator]}" Command="{Binding GoToCalculatorCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[CartTitle]}" Command="{Binding GoToCartCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Cabinet]}" Command="{Binding GoToCabinetCommand}" Style="{StaticResource NavButton}"/>
                    </StackPanel>
                    
                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Logout]}" Command="{Binding LogoutCommand}" Visibility="{Binding LogoutVisibility}" Style="{StaticResource NavButton}" Foreground="#FFB3B1" FontWeight="Bold"/>
                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LangName]}" Command="{Binding ToggleLanguageCommand}" Style="{StaticResource NavButton}" BorderBrush="#444444" BorderThickness="1" Padding="8,4" Margin="15,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ContentControl Content="{Binding CurrentViewModel}" Grid.Row="1" />
    </Grid>
</Window>
