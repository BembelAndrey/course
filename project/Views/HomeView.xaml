<UserControl x:Class="project.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:services="clr-namespace:project.Services"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="#131314">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="700">
            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Subtitle]}" FontSize="14" FontWeight="Bold" Foreground="#FFB3B1" TextAlignment="Center" Margin="0,0,0,10"/>
            
            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[MainSlogan]}" FontSize="38" FontWeight="Bold" Foreground="#FFFFFF" TextAlignment="Center" Margin="0,0,0,30" TextWrapping="Wrap"/>
            
            <Border Background="#1F1F20" CornerRadius="8" Padding="30" BorderBrush="#2A2A2B" BorderThickness="1" Margin="0,0,0,30">
                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[CompanyDesc]}" 
                           FontSize="16" TextWrapping="Wrap" TextAlignment="Center" Foreground="#CCCCCC" LineHeight="24"/>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1F1F20" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Walls]}" Foreground="#FFB3B1" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[WallsDesc]}" Foreground="#999999" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#1F1F20" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Floors]}" Foreground="#FFB3B1" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloorsDesc]}" Foreground="#999999" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="#1F1F20" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Ceilings]}" Foreground="#FFB3B1" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[CeilingsDesc]}" Foreground="#999999" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
