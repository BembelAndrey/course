<UserControl x:Class="project.Views.ExecutorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:services="clr-namespace:project.Services"
             xmlns:converters="clr-namespace:project.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1100"
             Background="#131314">
    <UserControl.Resources>
        <converters:LocalizedMaterialConverter x:Key="LocalizedMaterialConverter" />
        <converters:LanguageStringConverter x:Key="LanguageStringConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>
    
    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: Профиль, Заработок, Календарь -->
        <Border Grid.Column="0" Background="#1F1F20" CornerRadius="12" Padding="20" Margin="0,0,20,0" BorderBrush="#2A2A2B" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Профиль -->
                    <Border Width="80" Height="80" CornerRadius="40" Background="#2A2A2B" Margin="0,0,0,15">
                        <TextBlock Text="M" Foreground="#FFB3B1" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding FullName}" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF" TextAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[ExecutorRoleName]}" Foreground="#999999" FontSize="12" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,25"/>

                    <!-- Статистика -->
                    <Border Background="#131314" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#2A2A2B" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[MonthlyEarningsLbl]}" FontSize="11" Foreground="#999999" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding MonthlyEarnings, StringFormat='{}{0} $'}" FontSize="26" FontWeight="Bold" Foreground="#27AE60"/>
                        </StackPanel>
                    </Border>

                    <!-- Календарь -->
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[WorkScheduleLbl]}" FontSize="11" Foreground="#999999" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Border Background="#131314" CornerRadius="8" Padding="5" BorderBrush="#2A2A2B" BorderThickness="1">
                        <Calendar Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" DisplayMode="Month">
                            <Calendar.CalendarDayButtonStyle>
                                <Style TargetType="CalendarDayButton" BasedOn="{StaticResource {x:Type CalendarDayButton}}">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource CalendarDayColorConverter}">
                                                <Binding />
                                                <Binding Path="DataContext.WorkDays" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                </Style>
                            </Calendar.CalendarDayButtonStyle>
                        </Calendar>
                    </Border>

                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Logout]}" 
                            Command="{Binding LogoutCommand}" Style="{StaticResource NavButton}" 
                            Foreground="#FFB3B1" FontWeight="Bold" Margin="0,30,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Правая панель: Список текущих задач -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[CurrentTasksLbl]}" FontSize="26" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding Message}" Foreground="#FFB3B1" FontWeight="SemiBold" FontSize="14"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#1F1F20" CornerRadius="12" Padding="10" BorderBrush="#2A2A2B" BorderThickness="1">
                <DataGrid ItemsSource="{Binding MyActiveOrders}" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="Transparent" Foreground="#E0E0E0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2A2A2B" BorderThickness="0"
                          RowDetailsVisibilityMode="VisibleWhenSelected">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#999999"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Margin" Value="0,2"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="#131314" Padding="20" Margin="10" CornerRadius="10" BorderBrush="#2A2A2B" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AddressLbl]}" Foreground="#FFB3B1" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Address}" Foreground="#FFB3B1" FontSize="16" FontWeight="Bold" Margin="5,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RequiredMaterialsLbl]}" Foreground="#999999" Margin="0,0,0,12" FontSize="11" FontWeight="Bold"/>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Foreground="#E0E0E0" FontSize="14">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource LocalizedMaterialConverter}" ConverterParameter="Title">
                                                                <Binding Path="Material" />
                                                                <Binding Source="{x:Static services:TranslationSource.Instance}" Path="CurrentLanguage" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="30,0,0,0">
                                                        <TextBlock Text="{Binding Quantity}" Foreground="#27AE60" FontWeight="Bold" FontSize="14"/>
                                                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PcsLbl]}" Foreground="#27AE60" FontWeight="Bold" FontSize="14" Margin="5,0,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                        <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[StartDateLbl]}" Binding="{Binding OrderDate, StringFormat='{}{0:dd.MM.yyyy}'}" Width="Auto"/>
                        <DataGridTemplateColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[ObjectTypeLbl]}" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource LocalizedMaterialConverter}" ConverterParameter="OrderName">
                                                <Binding Path="." />
                                                <Binding Source="{x:Static services:TranslationSource.Instance}" Path="CurrentLanguage" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AreaLbl]}" Binding="{Binding Area, StringFormat='{}{0} м²'}" Width="Auto"/>
                        <DataGridTemplateColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[YourEarningsLbl]}" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EarningsConverter}}" 
                                               Foreground="#27AE60" FontWeight="Bold" VerticalAlignment="Center" FontSize="15"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[CompleteWorkBtn]}" Command="{Binding DataContext.CompleteOrderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" Background="#27AE60" Foreground="White" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
